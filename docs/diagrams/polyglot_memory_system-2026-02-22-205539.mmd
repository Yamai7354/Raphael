    %% ---------- Current implementation: components that use memory ----------
    subgraph Impl["Current implementation (wired in code)"]
        Director["Director / GraphReasoner"]
        Consolidation["ConsolidationWorker / GovernanceLayer"]
        AIRouter["AI Router (main)"]
    end

    subgraph WM["Working Memory"]
        Redis["Redis (In-Memory)"]
    end

    subgraph Episodic["Episodic Memory"]
        Timescale["TimescaleDB / PostgreSQL (Persistent Logs)"]
    end

    subgraph Procedural["Procedural Memory"]
        ProcStore["SQLite / ProceduralMemoryStore"]
    end

    subgraph OperationalKG["Operational Knowledge Graph"]
        Neo4jOp["Neo4j (graph_api: Agent & Task & Blueprint)"]
    end

    subgraph ResearchKG["Research & Learning Knowledge Graph"]
        Neo4jRes["Neo4j (ResearchKG: insights, skills)"]
        RDFStore["RDF / GraphDB (future)"]
    end

    subgraph VectorStore["Vector Store"]
        Milvus["LanceDB / Milvus / Qdrant"]
    end

    %% Actual connections (as implemented)
    Director --> Neo4jOp
    Consolidation --> Episodic
    Consolidation --> Procedural
    Consolidation --> Neo4jOp
    AIRouter --> Redis
    AIRouter --> Timescale

    %% Cross-store references (consolidation promotes Episodic -> Procedural/Semantic)
    Episodic -.-> Procedural
    Episodic -.-> Neo4jOp

